# Required
JWT_ACCESS_SECRET=change-this-to-a-random-secret
JWT_REFRESH_SECRET=change-this-to-another-random-secret

# Database (PostgreSQL, e.g. Supabase)
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Optional
NODE_ENV=production
CORS_ORIGIN=*
LOG_LEVEL=info
PORT=3000