{
  "name": "@schedule/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && prisma generate && nest build",
    "dev": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "dev:watch": "ts-node-dev --transpile-only --respawn --rs --watch src/main.ts",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.15",
    "@neondatabase/serverless": "^0.9.5",
    "@prisma/adapter-pg": "^6.1.0",
    "@prisma/adapter-neon": "^6.1.0",
    "ws": "^8.18.0",
    "@prisma/client": "^6.1.0",
    "@schedule/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/rrule": "^2.2.9",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
